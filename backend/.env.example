# Copy to .env and fill in. Never commit the real values.

# PropelAuth — required.
PROPELAUTH_AUTH_URL=
PROPELAUTH_API_KEY=

# Active Directory — required if using AD sync.
AD_URL=
AD_BASE_DN=
AD_USERNAME=
AD_PASSWORD=

# AES-256 key for app-level encryption (32 bytes recommended) — required.
# Protects AD bind password, network device SSH creds, SMTP and M365 secrets.
# There is no fallback: encrypt/decrypt calls throw if this is unset.
ENCRYPTION_KEY=

# Database
DB_HOST=
DB_PORT=
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
DB_SCHEMA=public

# Comma-separated allowed origins for browser callers.
CORS_ORIGINS=http://localhost:5173

# Set to 'true' only when this app runs behind a reverse proxy / load
# balancer that sets X-Forwarded-For. Enables trusting that header for
# rate-limiting and logging. Leave unset otherwise — a client could
# spoof its own IP and bypass per-IP rate limits if this is on without
# an actual proxy in front.
TRUST_PROXY=false

# Set to 'true' only on a dev machine you can wipe.
TYPEORM_SYNCHRONIZE=false

# Require MFA on sensitive modules (audit export, privacy erase/export, legal
# hold, retention run, AD sync, SMTP, M365, compliance, CVE, fleet). Set to
# 'true' in production — anything else (including leaving it unset) disables
# MFA enforcement app-wide.
MFA_REQUIRED=true

# Server
PORT=3000
NODE_ENV=production

# Pins the base URL baked into every Windows/macOS/Linux agent installer
# snippet (Settings > Windows Agent) to your TLS-terminating reverse proxy,
# e.g. https://192.168.1.41 (no port — 3000 is plain HTTP, never TLS).
# Without this, the URL is derived from whatever Host header the admin's
# browser sent, so opening Settings through the raw :3000 port by mistake
# bakes that wrong, TLS-less port into the snippet. Leave unset only for
# local dev (localhost).
AGENT_PUBLIC_BASE_URL=

# First-run bootstrap: if the users table is empty on startup, this email
# gets an admin account automatically. Remove or leave blank after first deploy.
ADMIN_EMAIL=

# ---- Optional integrations ----

# Grafana admin password (only used by docker-compose grafana service).
GRAFANA_ADMIN_PASSWORD=

# Audit log external sinks
AUDIT_SINK_FILE_PATH=
AUDIT_SINK_URL=
AUDIT_SINK_TOKEN=
AUDIT_SINK_FORMAT=generic
AUDIT_SINK_QUEUE_MAX=1000

# Outbound mail — configure SMTP_HOST to enable real sending.
# Corporate server example:  SMTP_HOST=mail.firma.pl  SMTP_PORT=587
# Gmail example:             SMTP_HOST=smtp.gmail.com SMTP_PORT=587  SMTP_USER=you@gmail.com  SMTP_PASS=app-password
# Without SMTP_HOST the service logs mails only (stub/dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM_ADDRESS=infrapilot@localhost

# Remote assist
REMOTE_ASSIST_BASE_URL=
REMOTE_ASSIST_TOKEN_SECRET=

# Agent installer downloads. Leave blank to self-host: upload the
# .exe/.pkg from Settings > Windows/macOS Agent and it's served from this
# backend at /devices/agent/installer?platform=windows|macos. Set these
# only to point at an external host (CDN / GitHub Releases) instead.
# AGENT_INSTALLER_URL (no suffix) is a legacy alias for AGENT_INSTALLER_URL_WINDOWS.
AGENT_INSTALLER_URL=
AGENT_INSTALLER_URL_WINDOWS=
AGENT_INSTALLER_URL_MACOS=

# Ticket auto-followup tuning
TICKET_AWAIT_REMIND_HOURS=48
TICKET_AWAIT_AUTOCLOSE_HOURS=168
