# Copy to .env and fill. Vite exposes only VITE_* prefixed vars to the bundle.

# PropelAuth tenant URL.
VITE_AUTH_URL=

# Backend API base URL.
VITE_API_URL=http://localhost:3000

# Socket.IO origin (ticket live-update gateway). Falls back to
# http://localhost:3000 if unset — that default only works for local dev;
# in any real deployment it must be set explicitly, or the browser tries to
# open a socket to the *client's own* machine instead of the server.
VITE_WS_URL=http://localhost:3000
