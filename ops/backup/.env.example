# InfraPilot backup/restore environment.
# Copy to /etc/infrapilot/backup.env (mode 0600, owner infrapilot-backup)
# and source from the cron wrapper. Never commit a real copy of this file.

# ---- PostgreSQL connection (source for backup, target for restore) ----
PGHOST=localhost
PGPORT=5432
PGDATABASE=AssetManager
PGUSER=infrapilot_backup
PGPASSWORD=

# ---- Backup behaviour ----
BACKUP_ENV=prod
BACKUP_DIR=/var/backups/infrapilot
BACKUP_RETENTION_DAYS=30
# Path to backend/uploads on this host. Leave empty to skip uploads.
UPLOADS_DIR=/srv/infrapilot/backend/uploads

# ---- Encryption passphrase ----
# Must be released from a secrets manager at cron time. Do NOT store plain.
BACKUP_ENCRYPT_PASSPHRASE=

# ---- Off-host copies (at least one required for DR-readiness) ----
# S3 or S3-compatible.
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=infrapilot/prod
# Standard AWS env vars: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION
# or AWS_PROFILE / AWS_ENDPOINT_URL_S3 for non-AWS providers.

# SSH target: user@host:/absolute/path
BACKUP_SSH_TARGET=

# ---- App audit log hook (optional) ----
# When set, backup/restore/verify post to the app's audit log so the action
# appears in the tamper-evident chain.
AUDIT_LOG_URL=https://infrapilot.example.com/audit/ingest
AUDIT_LOG_TOKEN=
