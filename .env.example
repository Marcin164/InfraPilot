# Root .env for docker-compose.yml — copy to .env and fill in.
# Never commit the real values. See backend/.env.example for the backend's
# own (larger) set of variables — that's a separate file, ./backend/.env.

DB_USERNAME=infrapilot
DB_PASSWORD=
DB_NAME=InfraPilot

# PropelAuth tenant URL — same value goes into backend/.env as
# PROPELAUTH_AUTH_URL.
VITE_AUTH_URL=

# Frontend build-time vars — Vite bakes these into the JS bundle at build
# time, so changing them requires `docker compose up -d --build frontend`,
# not just a restart. Must point at the Nginx entry point (see
# ops/nginx/infrapilot.conf), not directly at the api container's port —
# e.g. http://192.168.1.41/api and http://192.168.1.41, or once you have a
# domain + TLS: https://your-domain/api and https://your-domain.
VITE_API_URL=
VITE_WS_URL=
