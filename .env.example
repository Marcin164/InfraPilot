# Root-level env consumed by docker-compose. Copy to `.env` and fill in.
# Backend service-level vars come from ./backend/.env (loaded via env_file).

# --- Postgres (used by the `db` service and substituted into compose) ---
DB_USERNAME=lanventory
DB_PASSWORD=changeme
DB_NAME=lanventory

# --- Frontend build-time vars (baked into the Vite bundle) ---
# Must be reachable from the user's BROWSER, not from inside the container.
VITE_API_URL=http://localhost:3000
VITE_AUTH_URL=
